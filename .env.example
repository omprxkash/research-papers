# Copy this file to .env and fill in your keys.

# Required for ra summarize, ra gaps, ra review
LLM_API_KEY=

# Optional — raises Semantic Scholar rate limit from 100 to 1000 requests per 5 minutes
# Get one free at: https://www.semanticscholar.org/product/api
S2_API_KEY=

# Optional — change where the library database is stored (default: ~/.ra/library.db)
# RA_DATA_DIR=/path/to/your/ra-data
